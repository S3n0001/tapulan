# Directory for persistent data: the SQLite database and uploaded files.
# Mount this as a volume in production so data survives redeploys.
DATA_DIR=./data

# Seeds the initial admin password. IMPORTANT: this is only applied the
# FIRST time the database is seeded (i.e. on first run against an empty
# DATA_DIR). Changing it afterwards has no effect — update the password
# from Admin -> Settings instead.
ADMIN_PASSWORD=change-me

# Port the Next.js server listens on.
PORT=3000

# Optional: override the Next.js build output directory (.next by default).
# Useful if the default location isn't writable in your deployment image.
NEXT_DIST_DIR=.next
