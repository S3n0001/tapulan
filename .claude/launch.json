{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "dev-isolated",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "env": { "NEXT_DIST_DIR": ".next-preview" },
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "start",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "start-isolated",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "env": { "NEXT_DIST_DIR": ".next-preview" },
      "port": 3000,
      "autoPort": true
    }
  ]
}
